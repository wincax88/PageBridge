NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://pagebridge:pagebridge@localhost:5432/pagebridge?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pagebridge
S3_ACCESS_KEY_ID=pagebridge
S3_SECRET_ACCESS_KEY=pagebridge-secret
S3_FORCE_PATH_STYLE=true
